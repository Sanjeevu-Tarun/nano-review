# Server
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Browser pool size (2-3 recommended; reduce to 1 on low-memory machines)
BROWSER_POOL_SIZE=2

# Cache directory (defaults to .cache/ in project root)
# CACHE_DIR=/tmp/nanoreview-cache

# Set to 1 to skip cache pre-warming on startup
# DISABLE_WARMUP=0

# Vercel detection (set automatically by Vercel)
# VERCEL=1
